# ============================================================
# Supabase Configuration — EXAMPLE FILE (safe to commit)
# ============================================================
# Copy this file to .env and fill in your real values.
# Never commit your real .env file.
#
# Get these values from your Supabase project:
#   Dashboard → Project Settings → API
# ============================================================

# Your project's public URL (e.g. https://xyzabc.supabase.co)
SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL_HERE

# Your project's anon/public key (safe to use client-side)
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE

# The public URL of this Streamlit app — used as the OAuth redirect target.
# For local development this is http://localhost:8501
# For production, set this to your deployed app URL (e.g. https://yourapp.streamlit.app)
APP_URL=http://localhost:8501
